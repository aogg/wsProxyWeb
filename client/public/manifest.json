{
  "manifest_version": 3,
  "name": "WebSocket代理",
  "version": "1.0.0",
  "description": "通过WebSocket代理网页请求",
  "permissions": [
    "webRequest",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "<all_urls>"
  ]
}
