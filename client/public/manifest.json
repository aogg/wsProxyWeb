{
  "manifest_version": 3,
  "name": "WebSocket代理",
  "version": "1.1.4",
  "description": "通过WebSocket代理网页请求",
  "permissions": [
    "webRequest",
    "storage",
    "tabs",
    "scripting",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.svg",
      "48": "icons/icon.svg",
      "128": "icons/icon.svg"
    },
    "default_title": "WebSocket代理配置"
  },
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "host_permissions": [
    "<all_urls>"
  ]
}
